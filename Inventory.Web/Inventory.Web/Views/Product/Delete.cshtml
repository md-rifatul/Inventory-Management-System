@using Inventory.Domain.Entities
@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<h2 class="text-danger">Delete Product</h2>

<h4>Are you sure you want to delete this product?</h4>

<hr />

<div class="card p-3 mb-3">
    <dl class="row">

        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">SKU</dt>
        <dd class="col-sm-9">@Model.Sku</dd>

        <dt class="col-sm-3">Unit Price</dt>
        <dd class="col-sm-9">@Model.UnitPrice</dd>

        <dt class="col-sm-3">Quantity In Stock</dt>
        <dd class="col-sm-9">@Model.QuantityOfStock</dd>

        <dt class="col-sm-3">Category</dt>
        <dd class="col-sm-9">@Model.Category?.Name</dd>

    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>