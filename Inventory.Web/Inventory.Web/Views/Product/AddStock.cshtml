@using Inventory.Application.ViewModels
@model AddStockViewModel

@{
    ViewData["Title"] = "Add Stock";
}

<h2>Add Stock for @Model.ProductName</h2>

<form asp-action="AddStock" method="post">

    <input type="hidden" asp-for="ProductId" />

    <div class="form-group">
        <label>Product Name</label>
        <input asp-for="ProductName" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Current Stock</label>
        <input asp-for="CurrentStock" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Add Quantity</label>
        <input asp-for="AddQuantity" class="form-control" />
    </div>


    <button type="submit" class="btn btn-success">Update Stock</button>
    <a asp-action="LowStock" class="btn btn-secondary">Back to Low Stock List</a>
</form>