@model Inventory.Domain.Entities.Product

@{
    ViewData["Title"] = "Add Stock";
}

<h2>Add Stock for @Model.Name</h2>

<form asp-action="Add" method="post">
    <div class="form-group">
        <label>Product Name</label>
        <input asp-for="Name" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>SKU</label>
        <input asp-for="Sku" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Unit Price</label>
        <input asp-for="UnitPrice" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Current Stock</label>
        <input asp-for="QuantityOfStock" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Add Quantity</label>
        <input type="number" name="AddedQuantity" class="form-control" min="1" required />
    </div>

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-success">Update Stock</button>
    <a asp-action="LowStock" class="btn btn-secondary">Back to Low Stock List</a>
</form>