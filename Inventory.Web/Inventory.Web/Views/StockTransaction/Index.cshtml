@using Inventory.Domain.Entities
@model IEnumerable<StockTransaction>

@{
    ViewData["Title"] = "Stock Transactions";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-primary">
                <i class="bi bi-arrow-left-right me-2"></i>Stock Transaction History
            </h5>
            <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                <i class="bi bi-printer me-1"></i> Export PDF
            </button>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="transactionTable" class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Product Name</th>
                            <th class="text-center">Type</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end pe-4">Balance After</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@item.Id</td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Product?.Name</div>
                                    <div class="small text-muted">SKU: @item.Product?.Id</div>
                                </td>
                                <td class="text-center">
                                    @if (item.TransactionType.ToString() == "StockIn" || item.TransactionType.ToString() == "Addition")
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success px-3 border border-success">
                                            <i class="bi bi-plus-circle me-1"></i> @item.TransactionType
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger px-3 border border-danger">
                                            <i class="bi bi-dash-circle me-1"></i> @item.TransactionType
                                        </span>
                                    }
                                </td>
                                <td class="text-end fw-semibold">
                                    @item.Quantity
                                </td>
                                <td class="text-end pe-4 fw-bold text-secondary">
                                    @item.BlanceAfter
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Optional: Initialize DataTable for searching and sorting
            $('#transactionTable').DataTable({
                "pageLength": 10,
                "order": [[ 0, "desc" ]], // Show latest transactions first
                "dom": '<"p-3 d-flex justify-content-between"f>rt<"p-3 d-flex justify-content-between"ip>'
            });
        });
    </script>
}