@{
    ViewData["Title"] = "Payment Success";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 text-center p-4">

                <!-- Success Icon -->
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 80px;"></i>
                </div>

                <!-- Title -->
                <h2 class="text-success fw-bold">Payment Successful!</h2>

                <!-- Message -->
                <p class="mt-3 text-muted">
                    Thank you for your payment. Your transaction has been completed successfully.
                </p>

                <!-- Optional: Show Amount -->
                @if (ViewBag.Amount != null)
                {
                    <h4 class="mt-3">Amount Paid: <span class="text-primary">$@ViewBag.Amount</span></h4>
                }

                <!-- Buttons -->
                <div class="mt-4">
                    <a href="/" class="btn btn-primary px-4 me-2">Go to Home</a>
                    <a href="/Sales/Create" class="btn btn-outline-secondary px-4">Create New Order</a>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Icons CDN (if not already added) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">