@using Inventory.Application.ViewModels.SalesOrder
@model SalesOrderConfirmViewModel

@{
    ViewData["Title"] = "Order Confirmation Details";
}

<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
    <button class="btn btn-primary" onclick="downloadPDF()">
        <i class="bi bi-file-earmark-pdf-fill me-1"></i> Download PDF
    </button>
</div>

<div id="printableArea">
    <div class="container-fluid">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Order Confirmation: @Model.OrderNumber</h4>
                <span class="badge bg-light text-primary">ID: @Model.Id</span>
            </div>

            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-6">
                        <h5 class="border-bottom pb-2">Customer Details</h5>
                        <p class="mb-1"><strong>Name:</strong> @Model.CustomerName</p>
                        <p class="mb-1"><strong>Address:</strong> @Model.Address</p>
                        <p class="mb-1"><strong>Total Amount:</strong> <span class="text-success fw-bold">@Model.TotalAmount.ToString("C")</span></p>
                    </div>
                    <div class="col-6 text-end">
                        <h5 class="border-bottom pb-2">Order Summary</h5>
                        <p class="mb-1"><strong>Items Count:</strong> @Model.Items.Count</p>
                        <p class="mb-1"><strong>Date:</strong> @DateTime.Now.ToString("dd MMM yyyy")</p>
                        <p class="mb-1"><strong>Status:</strong> <span class="badge bg-info">@Model.Status</span></p>
                    </div>
                </div>

                <h5>Product List</h5>
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Product Name</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                    <td class="text-end fw-bold">@item.Subtotal.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary">
                                <td colspan="3" class="text-end fw-bold">Grand Total:</td>
                                <td class="text-end fw-bold">@Model.TotalAmount.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div id="web-actions" class="card-footer bg-white py-3 d-print-none">
                @if (Model.Status != "Completed")
                {
                    <form asp-action="ConfirmOrder" asp-route-id="@Model.Id" method="post" class="text-end">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success px-4"
                                onclick="return confirm('Confirm this order? Inventory will be updated.')">
                            <i class="bi bi-check-circle"></i> Confirm Order
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        function downloadPDF() {
            // Select the area to turn into PDF
            const element = document.getElementById('printableArea');

            // Set PDF options
            const opt = {
                margin:       0.5,
                filename:     'Order_@Model.OrderNumber' + '.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
            };

            // Clone the element so we can hide the 'Confirm Order' button in the PDF
            const clone = element.cloneNode(true);
            const actionFooter = clone.querySelector('#web-actions');
            if (actionFooter) {
                actionFooter.remove(); // Removes the button section from the PDF version only
            }

            // Generate and save the PDF
            html2pdf().set(opt).from(clone).save();
        }
    </script>
}