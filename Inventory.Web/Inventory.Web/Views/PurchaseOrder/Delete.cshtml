@using Inventory.Domain.Entities
@model PurchaseOrder

@{
    ViewData["Title"] = "Delete Purchase Order";
}

<h2 class="text-danger">Delete Purchase Order</h2>
<h4>Are you sure you want to delete this order?</h4>

<hr />

<div class="card p-3 mb-3">
    <dl class="row">
        <dt class="col-sm-3">Order Number</dt>
        <dd class="col-sm-9">@Model.OrderNumber</dd>

        <dt class="col-sm-3">Supplier</dt>
        <dd class="col-sm-9">@Model.Supplier?.Name</dd>

        <dt class="col-sm-3">Total Amount</dt>
        <dd class="col-sm-9">@Model.TotalAmount</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.purchaseOrderStatus</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>